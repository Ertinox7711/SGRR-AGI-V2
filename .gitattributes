# Deterministic line endings — a friend who clones on Mac/Linux must not
# get scripts broken by \r (CRLF).
* text=auto eol=lf

# Shell scripts + git hook: LF required (otherwise the shebang breaks on Unix).
*.sh            text eol=lf
*.bash          text eol=lf
scripts/hooks/* text eol=lf

# PowerShell scripts: CRLF (native Windows).
*.ps1 text eol=crlf

# Possible binaries — no normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
