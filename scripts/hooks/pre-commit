#!/usr/bin/env bash
# pre-commit — barrage anti-fuite (SGRR AGI V2)
# Scanne le diff STAGED. Refuse le commit si un motif de secret / PII apparaît.
# Installé par install.ps1 / install.sh dans .git/hooks/pre-commit.
# Git for Windows fournit bash, donc ce hook marche aussi sous Windows.
set -euo pipefail

# Fichiers staged (Added/Copied/Modified), en ignorant les binaires gérés par .gitignore.
staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

# Le contenu staged à inspecter (diff ajoutées uniquement).
added=$(git diff --cached --unified=0 -- $staged | grep -E '^\+' | grep -Ev '^\+\+\+' || true)

fail=0
flag() { printf '\033[31m[pre-commit] FUITE: %s\033[0m\n' "$1" >&2; fail=1; }

# Motifs de secrets (les placeholders <...> et noreply sont exclus plus bas)
echo "$added" | grep -Eq 'shp(at|ca|pa|ss)_[a-fA-F0-9]{32}'        && flag "token Shopify"
echo "$added" | grep -Eq 'sk-ant-[a-zA-Z0-9_-]{20,}'               && flag "clé Anthropic"
echo "$added" | grep -Eq 'sk-[a-zA-Z0-9]{20,}T3BlbkFJ'             && flag "clé OpenAI"
echo "$added" | grep -Eq 'gh[pousr]_[A-Za-z0-9]{36,}'              && flag "token GitHub"
echo "$added" | grep -Eq 'AKIA[0-9A-Z]{16}'                        && flag "clé AWS"
echo "$added" | grep -Eq 'xox[baprs]-[A-Za-z0-9-]{10,}'            && flag "token Slack"
echo "$added" | grep -Eiq '(api[_-]?key|secret|password|passwd|token)[[:space:]]*[:=][[:space:]]*['"'"'"][A-Za-z0-9_-]{24,}['"'"'"]' \
  && ! echo "$added" | grep -Eq '<[A-Z_]+>' && flag "secret générique assigné"

# PII : chemins home absolus
echo "$added" | grep -Eq '([A-Za-z]:\\Users\\[^\\/<> ]+)|(/home/[^/<> ]+)|(/Users/[^/<> ]+)' \
  && ! echo "$added" | grep -Eq '(you|user|name|runner)\b' && flag "chemin home absolu"

# PII : email réel (autorise noreply / example)
if echo "$added" | grep -Eioq '[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'; then
  if echo "$added" | grep -Eio '[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}' \
       | grep -Eiv '(noreply|users\.noreply\.github\.com|example\.(com|org)|@placeholder)' | grep -q '@'; then
    flag "email réel"
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Commit refusé : retire le secret/PII ci-dessus, ou si c'est un faux positif," >&2
  echo "ajuste .gitleaks.toml puis 'git commit --no-verify' (en connaissance de cause)." >&2
  exit 1
fi
exit 0
