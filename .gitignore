# ── SECRETS — NEVER COMMIT ──────────────────────────────────────────
# Hard-block. Anything that could hold a key, a token, or a credential.
.credentials.json
*.credentials.json
credentials.json
*.env
.env
.env.*
settings.local.json
*.local.json
*secret*
*token*
*apikey*
*api-key*
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*service-account*.json
gcp-*.json
# Shopify / Stripe / OpenAI / Anthropic / GitHub token shapes
shpat_*
shpss_*
sk-*
rk_*
ghp_*
gho_*

# ── EXCEPTIONS ──────────────────────────────────────────────────────
# Legit repo files whose NAME matches a pattern above
# (e.g. "secret-scan.yml" contains "secret" but it's our workflow).
!.github/workflows/secret-scan.yml

# ── SENSITIVE FOLDERS ───────────────────────────────────────────────
.aws/
.ssh/
.gnupg/

# ── LOCAL / RUNTIME NOISE ───────────────────────────────────────────
history.jsonl
*.log
*.bak
*.bak-*
cache/
debug/
shell-snapshots/
session-env/
sessions/
todos/
file-history/
paste-cache/
projects/
node_modules/
.DS_Store
Thumbs.db
